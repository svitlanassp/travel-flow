{
    "env": {
        "browser": true,
        "es6": true
    },
    "extends": [
        "airbnb-base"
    ],
    "globals": {
        "Atomics": "readonly",
        "SharedArrayBuffer": "readonly",
        "Auth": "readonly",
        "api": "writable"
    },
    "parserOptions": {
        "ecmaVersion": 2018,
        "sourceType": "script"
    },
    "rules": {
        "indent": ["error", 4],
        "linebreak-style": "off",
        "no-unused-vars": ["error", { "varsIgnorePattern": "^(api|_.*)" }]
    }
}